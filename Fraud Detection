    "# XGBoost (no scaling is needed for tree-based method)\n",
    "from xgboost import XGBClassifier\n",
    "\n",
    "neg = (y_train == 0).sum()\n",
    "pos = (y_train == 1).sum()\n",
    "\n",
    "model = XGBClassifier(\n",
